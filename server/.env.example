# Server Environment Variables
# Copy this file to .env and fill in your values

# Database (use Neon free tier for production)
DATABASE_URL="postgresql://user:password@localhost:5432/synco?schema=public"

# JWT Authentication
JWT_SECRET="your-secret-key-here"
JWT_EXPIRES_IN="7d"

# Client URL (for CORS) — comma-separated for multiple origins
# Local:      http://localhost:5173
# Production: https://your-app.netlify.app
CLIENT_URL="http://localhost:5173"

# Server Port (Render sets this automatically)
PORT=5000

# SMTP (for email OTP — Gmail App Password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
